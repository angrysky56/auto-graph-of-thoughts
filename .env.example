# Note: This .env file is OPTIONAL. If you already export these variables
# in your OS environment (e.g., ~/.bashrc or ~/.zshrc), the framework
# will prioritize and use those automatically!

# OpenRouter API Key for language models
# Get one at https://openrouter.ai/keys
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# (Optional) OpenRouter specific model ID
OPENROUTER_MODEL_ID=deepseek/deepseek-v4-flash

# Default Language Model choice. Must match a key in config.json or one of: openrouter, chatgpt
GOT_LANGUAGE_MODEL=openrouter

# OpenAI API Key (if you are using OpenAI directly instead of OpenRouter)
# OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (if you are using Anthropic directly)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
